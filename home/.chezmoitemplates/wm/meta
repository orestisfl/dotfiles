# Variables.
set $mod Mod4
set $alt Mod1

# `alacritty.sh` inherits the focused window's cwd.
set $term ~/bin/alacritty.sh
set $menu rofi -modes combi -show combi -combi-modes window#drun
{{- if .xorg }}
set $lock i3lock
{{- else if .wayland }}
# Keep the Wayland locker visually minimal; PAM handles fingerprint auth.
set $lock gtklock -d -g Adwaita-dark -s ~/.config/gtklock/style.css

# Hide the cursor after 3s idle.
seat * hide_cursor 3000
{{- end }}
