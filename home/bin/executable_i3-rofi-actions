#!/bin/bash
# i3-rofi-actions
# Use rofi to call systemctl for shutdown, reboot, etc
set -euo pipefail

declare -A options
declare -a options_order

have() {
    command -v "$1" >/dev/null 2>&1
}

add_option_if_file() {
    if [[ -f "$2" ]]; then
        add_option "$1" "$2"
    fi
}

add_option() {
    options["$1"]="$2"
    options_order+=("$1")
}

switch_autorandr() {
    autorandr --change --debug --default solo
}
export -f switch_autorandr

# Hand the LG HDR 4K back to the desktop PC: stop driving it from the laptop,
# then tell the monitor over DDC/CI to switch its input to HDMI2 (where the
# PC is plugged in). Under X11 we reuse the autorandr "solo" profile (which
# also turns off the HP); under sway we only disable the LG so the HP keeps
# working as a secondary display.
switch_monitor_to_pc() {
    if [[ -n "${SWAYSOCK:-}" ]]; then
        swaymsg output '"LG Electronics LG HDR 4K 301MAKRKFW57"' disable
    else
        autorandr --force --load solo
    fi

    ddcutil --model 'LG HDR 4K' setvcp xf4 x0091 \
        --i2c-source-addr=x50 --noverify --trcfile i2c_execute
}
export -f switch_monitor_to_pc

ddcutil_brightness() {
    value="$(zenity --entry --entry-text="$(ddcutil --model 'LG HDR 4K' getvcp 10 --brief | cut -d ' ' -f 4)")"
    [[ -n "$value" ]] || return 0

    (light -S "$value" || true) &
    (ddcutil --model 'LG HDR 4K' setvcp 10 "$value" || true) &
    ddcutil --model 'HP E27d G4' setvcp 10 "$value" || true
    wait
}
export -f ddcutil_brightness

bluetooth_on() {
    # Avoid hanging rofi if bluetoothd/controller isn't ready.
    btctl() {
        timeout 5s bluetoothctl "$@"
    }

    systemctl is-active bluetooth >/dev/null 2>&1 || systemctl start bluetooth >/dev/null 2>&1 || true

    local powered=false
    for i in {0..4}; do
        rfkill unblock bluetooth
        if btctl power on 2>&1 | grep -q "Changing power on\|succeeded"; then
            powered=true
            break
        fi
        sleep 1
    done

    $powered || {
        echo "Failed to power on bluetooth adapter" >&2
        return 1
    }
    sleep 1

    for i in {0..2}; do
        mapfile -t trusted_ids < <(btctl devices Trusted | awk '{print $2}')
        for id in "${trusted_ids[@]}"; do
            [[ -n "$id" ]] || continue
            btctl connect "$id" && return 0 || true
        done
        sleep 1
    done

    have blueman-manager && {
        blueman-manager &
        disown
    }
}
export -f bluetooth_on

bluetooth_off() {
    btctl() {
        timeout 5s bluetoothctl "$@"
    }

    mapfile -t connected_ids < <(btctl devices Connected | awk '{print $2}')
    for id in "${connected_ids[@]}"; do
        [[ -n "$id" ]] || continue
        btctl disconnect "$id" || true
    done

    btctl power off || true
    rfkill block bluetooth || true
    systemctl stop bluetooth.service >/dev/null 2>&1 || true
    killall blueman-applet blueman-tray blueman-manager || true
}
export -f bluetooth_off

run_action() {
    local action="$1"

    if declare -F "$action" >/dev/null; then
        "$action"
        return
    fi

    if [[ -f "$action" ]]; then
        "$action"
        return
    fi

    bash -lc "$action"
}

# Fill options.
have gcalcli && ! pidof zoom >/dev/null 2>&1 && add_option "Join zoom meeting" "$HOME/bin/join-zoom.sh"
pidof zoom >/dev/null 2>&1 && add_option "Kill zoom" "killall zoom & killall aomhost & wait"

add_option_if_file "Rename workspace" "$HOME/bin/i3-workspace-rename.py"
have bluetoothctl &&
    add_option "Bluetooth on" "bluetooth_on" &&
    add_option "Bluetooth off" "bluetooth_off"

if [[ -n "${SWAYSOCK:-}" ]]; then
    add_option "Sleep monitor" "swaymsg 'output * power off'"
    add_option "Exit" "swaymsg exit"
else
    add_option "Sleep monitor" "xset dpms force suspend; sleep 0.1; xset dpms force suspend"
    add_option "Exit" "i3-msg exit"
fi
add_option "Suspend system" "systemctl suspend"
add_option "Reboot system" "systemctl reboot"
add_option "Power-off system" "systemctl poweroff"

# External-display helpers (ddcutil is display-server independent; autorandr is
# X11 only). Detect an external output in either compositor.
if [[ -n "${SWAYSOCK:-}" ]]; then
    external_connected() {
        swaymsg -t get_outputs 2>/dev/null |
            jq -e '[.[] | select(.active and (.name | test("^(DP|HDMI)-"))) ] | length > 0' \
                >/dev/null 2>&1
    }
else
    have autorandr && add_option "Autorandr" switch_autorandr
    external_connected() {
        have xrandr && xrandr | grep -Eq '\b(DP|HDMI)-[0-9]+ connected'
    }
fi

# 0x0090 = HDMI1
# 0x0091 = HDMI2
# 0x00D0 = DP-1
# 0x00D1 = DP-2
# 0x00D2 = USB-C
if external_connected; then
    add_option "Change external monitor brightness" ddcutil_brightness
    add_option "Switch monitor to PC" switch_monitor_to_pc
fi

options_len="${#options_order[@]}"
printf '%s\n' "${options_order[@]}"

selection="$(
    printf '%s\n' "${options_order[@]}" |
        rofi -matching fuzzy -l "$options_len" -dmenu -i -p 'Pick action: ' |
        tr -d '\r\n'
)"

[[ -n "$selection" ]] || exit 0
action="${options[$selection]:-}"
[[ -n "$action" ]] || exit 0

out="$(run_action "$action" 2>&1)" || zenity --error --text="Command failed: $out" --no-markup
