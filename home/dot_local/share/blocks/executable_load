#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "${BASH_SOURCE[0]}")/block_format.sh"

INSTANCE="${BLOCK_INSTANCE:-1}"

URGENT_VALUE=90

LOAD=$(cat /proc/loadavg | awk -F ' ' '{print $'"${INSTANCE}"'}')
if [[ ${LOAD} != "" ]]; then
    LOAD_PERC=$(echo "scale=0; ${LOAD} * 100" | bc -l)
    LOAD_PERC=${LOAD_PERC%.*}

    if [[ ${LOAD_PERC} -ge ${URGENT_VALUE} ]]; then
        block_output_emit_urgent "${LOAD}" "${LOAD}" "${BLOCK_COLOR_WARNING}"
    else
        block_output_emit "${LOAD}"
    fi
fi
