#!/usr/bin/env bash
# Based on https://aur.archlinux.org/packages/playerctl/
set -euo pipefail

source "$(dirname "${BASH_SOURCE[0]}")/block_format.sh"

INSTANCE="${BLOCK_INSTANCE:-}"

if [[ -n "${INSTANCE}" ]]; then
    ARGUMENTS="--player ${INSTANCE}"
else
    ARGUMENTS=""
fi

ICON_PLAY="➤"
ICON_PAUSE="Ⅱ"
ICON_STOP="≠"
CUR_ICON=""

case "${BLOCK_BUTTON:-}" in
1)
    playerctl ${ARGUMENTS} previous >/dev/null 2>&1 || true
    ;;
2)
    playerctl ${ARGUMENTS} play-pause >/dev/null 2>&1 || true
    ;;
3)
    playerctl ${ARGUMENTS} next >/dev/null 2>&1 || true
    ;;
esac

PLAYER_STATUS=$(playerctl ${ARGUMENTS} status 2>/dev/null) || exit 0
INFO_TITLE=$(playerctl ${ARGUMENTS} metadata title 2>/dev/null || true)
INFO_ARTIST=$(playerctl ${ARGUMENTS} metadata artist 2>/dev/null || true)

if [[ -z "${INFO_TITLE}" ]]; then
    exit 0
fi

if [[ "${PLAYER_STATUS}" = "Paused" ]]; then
    CUR_ICON="${ICON_PAUSE}"
elif [[ "${PLAYER_STATUS}" = "Playing" ]]; then
    CUR_ICON="${ICON_PLAY}"
else
    CUR_ICON="${ICON_STOP}"
fi

if [[ -n "${INFO_ARTIST}" ]]; then
    output="${INFO_ARTIST} - ${INFO_TITLE} ${CUR_ICON}"
else
    output="${INFO_TITLE} ${CUR_ICON}"
fi

block_output_emit "${output}" "${CUR_ICON}"
