#!/usr/bin/env bash
# Active XKB layout. Subscribes to sway "input" events or xkb-switch -W.
set -u

short_name() {
    case "$1" in
    "English (US)" | "English" | "US") echo "us" ;;
    "Greek") echo "gr" ;;
    "") echo "?" ;;
    *) echo "$1" ;;
    esac
}

sway_layout() {
    swaymsg -t get_inputs 2>/dev/null |
        jq -r '[.[] | select(.type == "keyboard" and .xkb_active_layout_name != null) | .xkb_active_layout_name] | first // ""'
}

if [[ -n "${SWAYSOCK:-}" ]] && command -v swaymsg >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    short_name "$(sway_layout)"
    swaymsg -t subscribe -m '[ "input" ]' 2>/dev/null |
        while IFS= read -r _; do
            short_name "$(sway_layout)"
        done
elif command -v xkb-switch >/dev/null 2>&1; then
    xkb-switch
    exec xkb-switch -W
else
    echo "?"
fi
