#!/bin/bash
set -euo pipefail

source "$(dirname "${BASH_SOURCE[0]}")/block_format.sh"

case "${BLOCK_BUTTON:-}" in
"1") # Left click
    xdg-terminal-exec sh -c 'echo SYSTEM-WIDE FAILED UNITS:; systemctl --failed; echo; echo USER FAILED UNITS:; systemctl --user --failed; echo; read -p "Press enter to close..."' &
    ;;
"3") # Right click
    systemctl --user reset-failed
    systemctl --failed --quiet && systemctl reset-failed
    ;;
esac

function match() {
    local regex="([0-9]+) loaded units listed.*"
    if [[ $1 =~ $regex ]]; then
        failed_count="${BASH_REMATCH[1]}"
        echo "$failed_count"
    else
        return 1
    fi
}

res1=$(match "$(systemctl --failed)")
res2=$(match "$(systemctl --user --failed)")
res=$((res1 + res2))

if [[ $res -gt 0 ]]; then
    block_output_emit_urgent \
        "systemctl --failed: $res" \
        "$res" \
        "${BLOCK_COLOR_CRITICAL}"
fi
