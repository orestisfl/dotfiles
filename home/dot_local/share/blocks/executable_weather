#!/usr/bin/env bash
# Based on http://openweathermap.org/current
set -euo pipefail

source "$(dirname "${BASH_SOURCE[0]}")/block_format.sh"

API_KEY="ecf9f4fefedf777461f6d6935b6c3138"

# Check on http://openweathermap.org/find
CITY_ID="${BLOCK_INSTANCE:-}"
[[ -n "${CITY_ID}" ]] || exit 0

URGENT_LOWER=0
URGENT_HIGHER=30

ICON_SUNNY=""
ICON_CLOUDY=""
ICON_RAINY=""
ICON_STORM=""
ICON_SNOW=""
ICON_FOG=""

SYMBOL_CELSIUS="℃"

WEATHER_URL="http://api.openweathermap.org/data/2.5/weather?id=${CITY_ID}&appid=${API_KEY}&units=metric"

WEATHER_INFO=$(wget -qO- "${WEATHER_URL}")
WEATHER_MAIN=$(jq -r '.weather[0].main // empty' <<<"${WEATHER_INFO}")
WEATHER_TEMP=$(jq -r '.main.temp // empty' <<<"${WEATHER_INFO}" | cut -d '.' -f 1)
[[ -n "${WEATHER_MAIN}" && -n "${WEATHER_TEMP}" ]] || exit 0

if [[ "${WEATHER_MAIN}" = *Snow* ]]; then
    output="${ICON_SNOW} ${WEATHER_TEMP}${SYMBOL_CELSIUS}"
elif [[ "${WEATHER_MAIN}" = *Rain* ]] || [[ "${WEATHER_MAIN}" = *Drizzle* ]]; then
    output="${ICON_RAINY} ${WEATHER_TEMP}${SYMBOL_CELSIUS}"
elif [[ "${WEATHER_MAIN}" = *Thunderstorm* ]]; then
    output="${ICON_STORM} ${WEATHER_TEMP}${SYMBOL_CELSIUS}"
elif [[ "${WEATHER_MAIN}" = *Cloud* ]]; then
    output="${ICON_CLOUDY} ${WEATHER_TEMP}${SYMBOL_CELSIUS}"
elif [[ "${WEATHER_MAIN}" = *Clear* ]]; then
    output="${ICON_SUNNY} ${WEATHER_TEMP}${SYMBOL_CELSIUS}"
elif [[ "${WEATHER_MAIN}" = *Fog* ]] || [[ "${WEATHER_MAIN}" = *Mist* ]]; then
    output="${ICON_FOG} ${WEATHER_TEMP}${SYMBOL_CELSIUS}"
else
    output="${WEATHER_MAIN} ${WEATHER_TEMP}${SYMBOL_CELSIUS}"
fi

if [[ "${WEATHER_TEMP}" -lt "${URGENT_LOWER}" ]] || [[ "${WEATHER_TEMP}" -gt "${URGENT_HIGHER}" ]]; then
    block_output_emit_urgent "${output}" "${output}" "${BLOCK_COLOR_WARNING}"
else
    block_output_emit "${output}"
fi
